{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "blog.swipelink.fr" }],
      "destination": "https://swipelink.fr/:path*",
      "permanent": true
    },
    {
      "source": "/demo",
      "destination": "https://calendar.app.google/DrpxSVXXZdmPwbrh7",
      "permanent": false
    },
    {
      "source": "/rdv",
      "destination": "https://calendar.app.google/DrpxSVXXZdmPwbrh7",
      "permanent": false
    },
    {
      "source": "/agenda",
      "destination": "https://calendar.app.google/DrpxSVXXZdmPwbrh7",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "https://app.swipelink.fr/recruiter/auth",
      "permanent": false
    },
    {
      "source": "/app",
      "destination": "https://app.swipelink.fr/recruiter/auth",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|woff2|woff|ttf|otf|svg|png|jpg|jpeg|webp|avif|gif|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    }
  ]
}
